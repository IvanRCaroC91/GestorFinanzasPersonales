import React, { useState, useEffect } from 'react';
import {
    Box,
    Card,
    CardContent,
    Typography,
    Grid,
    Table,
    TableBody,
    TableCell,
    TableContainer,
    TableHead,
    TableRow,
    Chip,
    Button,
    CircularProgress,
    IconButton,
} from '@mui/material';
import {
    TrendingUp,
    TrendingDown,
    AccountBalance,
    Category,
    Edit,
} from '@mui/icons-material';
import { useNavigate } from 'react-router-dom';
import financeService from '../services/financeService';
import { Categoria, Movimiento } from '../types/finance';
import { tipoMovimientoLabel, tipoCategoriaLabel } from '../utils/tipoMovimientoMapper';

interface ResumenData {
    totalIngresos: number;
    totalGastos: number;
    balance: number;
    totalCategorias: number;
}

const DashboardPage: React.FC = () => {
    const navigate = useNavigate();

    const [resumen, setResumen] = useState<ResumenData>({
        totalIngresos: 0,
        totalGastos: 0,
        balance: 0,
        totalCategorias: 0,
    });

    const [movimientosRecientes, setMovimientosRecientes] = useState<Movimiento[]>([]);
    const [categoriasRecientes, setCategoriasRecientes] = useState<Categoria[]>([]);
    const [loading, setLoading] = useState(true);

    useEffect(() => {
        loadDashboardData();
    }, []);

    const loadDashboardData = async () => {
        try {
            setLoading(true);

            const [movimientosRes, categoriasRes] = await Promise.all([
                financeService.getMovimientos(),
                financeService.getCategorias(),
            ]);

            const movimientos = movimientosRes.success ? movimientosRes.data : [];
            const categorias = categoriasRes.success ? categoriasRes.data : [];

            const ingresos = movimientos
                .filter(m => m.tipo === 'INGRESO')
                .reduce((acc, m) => acc + m.valor, 0);

            const gastos = movimientos
                .filter(m => m.tipo === 'EGRESO')
                .reduce((acc, m) => acc + m.valor, 0);

            setResumen({
                totalIngresos: ingresos,
                totalGastos: gastos,
                balance: ingresos - gastos,
                totalCategorias: categorias.length,
            });

            setMovimientosRecientes(movimientos.slice(0, 5));
            setCategoriasRecientes(categorias.slice(0, 5));

        } finally {
            setLoading(false);
        }
    };

    const formatCurrency = (amount: number) =>
        new Intl.NumberFormat('es-CO', {
            style: 'currency',
            currency: 'COP',
            maximumFractionDigits: 0,
        }).format(amount);

    if (loading) {
        return (
            <Box sx={{ display: 'flex', justifyContent: 'center', mt: 10 }}>
                <CircularProgress />
            </Box>
        );
    }

    return (
        <Box
            sx={{
                width: '100%',
                px: { xs: 2, sm: 4, md: 6, lg: 10 },
            }}
        >
            {/* HEADER */}
            <Box sx={{ mb: 4 }}>
                <Typography variant="h4" fontWeight="bold">
                    Dashboard Financiero
                </Typography>
                <Typography color="text.secondary">
                    Resumen general de tus finanzas personales
                </Typography>
            </Box>

            {/* CARDS */}
            <Grid container spacing={3} sx={{ mb: 4 }}>
                {[
                    {
                        label: 'Ingresos',
                        value: resumen.totalIngresos,
                        icon: <TrendingUp color="primary" />,
                        color: 'primary.main',
                    },
                    {
                        label: 'Gastos',
                        value: resumen.totalGastos,
                        icon: <TrendingDown color="error" />,
                        color: 'error.main',
                    },
                    {
                        label: 'Balance',
                        value: resumen.balance,
                        icon: <AccountBalance color="info" />,
                        color: resumen.balance >= 0 ? 'primary.main' : 'error.main',
                    },
                    {
                        label: 'Categorías',
                        value: resumen.totalCategorias,
                        icon: <Category color="secondary" />,
                        color: 'secondary.main',
                        isNumber: true,
                    },
                ].map((item, i) => (
                    <Grid item xs={12} sm={6} md={4} lg={3} key={i}>
                        <Card
                            sx={{
                                p: 3,
                                display: 'flex',
                                alignItems: 'center',
                                gap: 2,
                                height: '100%',
                            }}
                        >
                            {item.icon}

                            <Box sx={{ flex: 1, minWidth: 0 }}>
                                <Typography
                                    sx={{
                                        fontWeight: 'bold',
                                        color: item.color,
                                        fontSize: {
                                            xs: '0.9rem',
                                            sm: '1.2rem',
                                            md: '1.4rem',
                                            lg: '1.7rem',
                                            xl: '2rem',
                                        },
                                        whiteSpace: 'nowrap',
                                    }}
                                >
                                    {item.isNumber
                                        ? item.value
                                        : formatCurrency(item.value)}
                                </Typography>

                                <Typography variant="body2" color="text.secondary">
                                    {item.label}
                                </Typography>
                            </Box>
                        </Card>
                    </Grid>
                ))}
            </Grid>

            {/* CONTENIDO */}
            <Grid container spacing={3}>
                {/* MOVIMIENTOS */}
                <Grid item xs={12} lg={8}>
                    <Card>
                        <CardContent>
                            <Typography variant="h6" fontWeight="bold" mb={2}>
                                Movimientos Recientes
                            </Typography>

                            <TableContainer>
                                <Table>
                                    <TableHead>
                                        <TableRow>
                                            <TableCell>Descripción</TableCell>
                                            <TableCell align="right">Monto</TableCell>
                                            <TableCell align="center">Tipo</TableCell>
                                        </TableRow>
                                    </TableHead>

                                    <TableBody>
                                        {movimientosRecientes.map(m => (
                                            <TableRow key={m.id}>
                                                <TableCell>{m.descripcion}</TableCell>
                                                <TableCell align="right">
                                                    <Typography
                                                        sx={{
                                                            fontWeight: 600,
                                                            whiteSpace: 'nowrap',
                                                        }}
                                                    >
                                                        {formatCurrency(m.valor)}
                                                    </Typography>
                                                </TableCell>
                                                <TableCell align="center">
                                                    <Chip
                                                        label={tipoMovimientoLabel[m.tipo]}
                                                        color={m.tipo === 'INGRESO' ? 'success' : 'warning'}
                                                    />
                                                </TableCell>
                                            </TableRow>
                                        ))}
                                    </TableBody>
                                </Table>
                            </TableContainer>
                        </CardContent>
                    </Card>
                </Grid>

                {/* CATEGORÍAS */}
                <Grid item xs={12} lg={4}>
                    <Card>
                        <CardContent>
                            <Typography variant="h6" fontWeight="bold" mb={2}>
                                Categorías Recientes
                            </Typography>

                            {categoriasRecientes.map(cat => (
                                <Box key={cat.id} sx={{ mb: 2 }}>
                                    <Typography>{cat.nombre}</Typography>
                                    <Chip
                                        label={tipoCategoriaLabel[cat.tipo]}
                                        size="small"
                                        color={cat.tipo === 'INGRESO' ? 'success' : 'warning'}
                                    />
                                </Box>
                            ))}
                        </CardContent>
                    </Card>
                </Grid>
            </Grid>
        </Box>
    );
};

export default DashboardPage;